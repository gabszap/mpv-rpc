{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist/",
    "typeRoots": [
      "./@types",
      "./node_modules/@types"
    ],
    "baseUrl": ".",
    "paths": {
      "premid": [
        "./premid/src"
      ]
    }
  },
  "include": [
    "presence.ts"
  ]
}