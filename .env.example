# Discord Application Client ID
DISCORD_CLIENT_ID=1450169544701378570

# MPV executable path (optional - searches in default directories if not set)
# Windows example: C:\Program Files\mpv\mpv.exe
# Linux example: /usr/bin/mpv
MPV_PATH=

# Settings
# Show anime cover as large image
SHOW_COVER=true
# Hide all media details
PRIVACY_MODE=false
# Hide status when MPV is idling
HIDE_IDLING=false
# Use anime title as activity name instead of "MPV"
SHOW_TITLE=true
# Preferred language for the title (THIS IS ANIME TITLE NAME): "english" or "eng", "romaji" or "none" (use filename), 
TITLE_LANG=none
# Metadata provider: jikan (MAL), anilist, kitsu or tvdb
METADATA_PROVIDER=jikan
# Enable Discord Rich Presence
DISCORD_RPC=true
# Enable detailed provider/API error logs in .anime_cache/api_log.txt
DEBUG=false

# ----- GuessIt Parser -----
# Use GuessIt API for filename parsing (recommended - no local Python needed)
USE_GUESSIT_API=true
# URL of your GuessIt API (deploy to Vercel, see guessit-api/README.md)
GUESSIT_API_URL=https://guessit-api.vercel.app/api/parse

# ----- TheTVDB -----
# TVDB API key (get one at https://thetvdb.com/api-information)
# Required when use tvdb as metadata provider, also used as fallback for episode titles
TVDB_API_KEY=
# Language for TVDB data (episode titles, descriptions)
# Examples: eng, por, jpn, spa, fra, deu, ita, rus
# See: https://en.wikipedia.org/wiki/List_of_ISO_639_language_codes for available language codes
TVDB_LANG=eng

# ----- MAL Sync -----
# Enable MAL sync (mark episodes as watched)
MAL_SYNC=false
# Your MAL API Client ID (get one at https://myanimelist.net/apiconfig)
MAL_CLIENT_ID=
# Percentage watched to trigger sync (default: 90)
MAL_SYNC_THRESHOLD=90
