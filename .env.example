# Discord Application Client ID
DISCORD_CLIENT_ID=

# MPV IPC Path (optional - auto-detected by OS)
# Windows: \\.\pipe\mpv
# Linux/macOS: /tmp/mpv-socket
MPV_IPC_PATH=

# Settings
# Show anime cover as large image
SHOW_COVER=true
# Hide all media details
PRIVACY_MODE=false
# Hide status when MPV is idling
HIDE_IDLING=false
# Use anime title as activity name instead of "MPV"
SHOW_TITLE_AS_PRESENCE=true
# Preferred language for the title: "english", "romaji" or "none" (use filename)
PREFERRED_TITLE_LANGUAGE=none
