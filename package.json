{
  "name": "mpv-rpc",
  "version": "2.0.0",
  "description": "Discord Rich Presence for MPV Media Player",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "bridge": "npm run start --workspace=stremio-mpv-bridge",
    "test": "vitest run",
    "release:dry:root": "dotenv -e .env -v RELEASE_SCOPE=root -- semantic-release --dry-run",
    "release:root": "dotenv -e .env -v RELEASE_SCOPE=root -- semantic-release",
    "release:dry:bridge": "dotenv -e .env -v RELEASE_SCOPE=bridge -- semantic-release --dry-run",
    "release:bridge": "dotenv -e .env -v RELEASE_SCOPE=bridge -- semantic-release",
    "release:dry": "npm run release:dry:root",
    "release:local": "npm run release:root"
  },
  "workspaces": [
    "stremio-mpv-bridge"
  ],
  "keywords": [
    "mpv",
    "discord",
    "rpc",
    "rich-presence"
  ],
  "license": "MIT",
  "dependencies": {
    "@xhayper/discord-rpc": "^1.2.0",
    "axios": "^1.7.0",
    "discord-api-types": "^0.38.47",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@semantic-release/npm": "^13.1.2",
    "@types/node": "^22.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "dotenv-cli": "^11.0.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
