    "rpc",
    "rich-presence"
  ],
  "license": "MIT",
  "dependencies": {
    "@xhayper/discord-rpc": "^1.2.0",
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}