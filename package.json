{
  "name": "mpv-rpc",
  "version": "1.0.4",
  "description": "Discord Rich Presence for MPV Media Player",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "start:bridge": "npm run start --workspace=stremio-mpv-bridge",
    "test": "vitest run"
  },
  "workspaces": [
